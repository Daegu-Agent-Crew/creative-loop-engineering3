{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Episode Decision Log",
  "type": "object",
  "required": ["episode_id", "decisions"],
  "properties": {
    "episode_id": { "type": "string" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "made_at", "decision", "rationale", "confidence", "human_approval"],
        "properties": {
          "id": { "type": "string" },
          "made_at": { "type": "string" },
          "phase": { "type": "string" },
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "uncertainties": { "type": "array", "items": { "type": "string" } },
          "alternatives_considered": { "type": "array", "items": { "type": "string" } },
          "human_approval": { "type": "string", "enum": ["pending", "approved", "rejected", "not_required", "provisional"] },
          "impact": { "type": "string" }
        }
      }
    }
  }
}
