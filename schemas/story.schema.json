{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Output",
  "type": "object",
  "required": [
    "episode_id",
    "title",
    "scenes",
    "prompt_version"
  ],
  "properties": {
    "episode_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scene_number",
          "description",
          "dialogue"
        ],
        "properties": {
          "scene_number": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          },
          "dialogue": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "character": {
                  "type": "string"
                },
                "line": {
                  "type": "string"
                }
              }
            }
          },
          "applied_principles": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(TB|HM)-[0-9]{2}$"
            }
          },
          "color_palette": {
            "type": "string"
          },
          "lighting": {
            "type": "string"
          },
          "emotion_intensity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          }
        }
      }
    },
    "cliffhanger": {
      "type": "object",
      "properties": {
        "page": {
          "type": "integer"
        },
        "type": {
          "type": "string"
        },
        "cliffhanger_type": {
          "type": "string",
          "enum": [
            "mystery",
            "danger",
            "reversal",
            "promise"
          ]
        },
        "text": {
          "type": "string"
        }
      }
    },
    "cold_open": {
      "type": "string"
    },
    "concept_seeding": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "silence_pages": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "applied_principles": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(TB|HM)-[0-9]{2}$"
      }
    },
    "prompt_version": {
      "type": "string"
    },
    "source_reference": {
      "type": "string"
    }
  }
}
