{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Panel Generation Jobs",
  "type": "object",
  "required": ["episode_id", "jobs", "policy"],
  "properties": {
    "episode_id": {
      "type": "string"
    },
    "policy": {
      "type": "object",
      "properties": {
        "batch_strategy": {
          "type": "string"
        },
        "text_strategy": {
          "type": "string"
        },
        "parallel_limit": {
          "type": "integer"
        },
        "complex_parallel_limit": {
          "type": "integer"
        }
      }
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["job_id", "page_number", "panel_ids", "status", "decision_rationale", "confidence"],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "page_number": {
            "type": "integer"
          },
          "panel_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "character_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "complexity": {
            "type": "string",
            "enum": ["simple", "standard", "complex"]
          },
          "text_overlay_required": {
            "type": "boolean"
          },
          "retry_count": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "running",
              "in_progress",
              "partial",
              "completed",
              "blocked",
              "failed",
              "retry_ready",
              "escalated"
            ]
          },
          "worker_tier": {
            "type": "string"
          },
          "image_model": {
            "type": "string"
          },
          "started_at": {
            "type": ["string", "null"]
          },
          "completed_at": {
            "type": ["string", "null"]
          },
          "generation_duration_seconds": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "qa_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 50
          },
          "last_error": {
            "type": ["string", "null"]
          },
          "decision_rationale": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "assumptions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "uncertainties": {
            "type": "array",
            "items": { "type": "string" }
          },
          "references_used": {
            "type": "array",
            "items": { "type": "string" }
          },
          "human_approval_required": {
            "type": "boolean"
          },
          "escalation_reason": {
            "type": ["string", "null"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
