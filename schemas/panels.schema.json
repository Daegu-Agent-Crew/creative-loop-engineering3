{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Panel Image Output",
  "type": "object",
  "required": ["episode_id", "panels", "prompt_version"],
  "properties": {
    "episode_id": {
      "type": "string"
    },
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["panel_id", "image_path", "generation_prompt"],
        "properties": {
          "panel_id": {
            "type": "string"
          },
          "page_number": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          },
          "camera_angle": {
            "type": "string"
          },
          "visual_type": {
            "type": "string",
            "enum": ["normal", "impact", "silence"]
          },
          "characters_in_frame": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reference_assets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "image_path": {
            "type": "string"
          },
          "generation_prompt": {
            "type": "string"
          },
          "style": {
            "type": "string"
          },
          "generation_status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "running",
              "generated",
              "qa_checking",
              "approved",
              "failed",
              "retry_ready",
              "escalated",
              "selected",
              "deprecated"
            ]
          },
          "attempt_count": {
            "type": "integer",
            "minimum": 0
          },
          "complexity": {
            "type": "string",
            "enum": ["simple", "standard", "complex"]
          },
          "worker_tier": {
            "type": "string"
          },
          "image_model": {
            "type": "string"
          },
          "started_at": {
            "type": ["string", "null"]
          },
          "completed_at": {
            "type": ["string", "null"]
          },
          "generation_duration_seconds": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "qa_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 50
          },
          "last_error": {
            "type": ["string", "null"]
          },
          "text_strategy": {
            "type": "string",
            "enum": ["postprocess_overlay", "image_text", "none"]
          },
          "ai_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 50
          },
          "human_score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 50
          }
        }
      }
    },
    "prompt_version": {
      "type": "string"
    }
  }
}
